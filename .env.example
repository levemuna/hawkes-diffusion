# Copy this to .env and fill in the values. .env is gitignored.

# ---------- Data source ----------
# One of: mock | scraping_browser | snowflake | brightdata
# - "scraping_browser": Playwright over CDP via BrightData hosted Chrome
#   (RECOMMENDED for live demos — bypasses Twitter anti-bot, gets full DOM)
# - "snowflake": query BrightData data via Snowflake Data Exchange (bulk historical)
# - "brightdata": call BrightData's REST Datasets API directly
# - "mock": no external calls, synthetic demo data
DATA_SOURCE=mock

# ---------- BrightData Scraping Browser ----------
# Full WSS endpoint from BrightData → Proxies → your Scraping Browser zone.
# Format: wss://brd-customer-<CUSTOMER>-zone-<ZONE>:<PASSWORD>@brd.superproxy.io:9222
# IMPORTANT: this string contains the password. Never commit .env.
BRIGHTDATA_SB_WSS=

# ---------- Snowflake (BrightData Data Exchange) ----------
# Account identifier — looks like "xy12345.us-east-1" or "abc-defghij"
# Find it in your Snowflake URL: the part before .snowflakecomputing.com
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# The shared database name BrightData published to your account.
# Open Snowflake → Data → Shared Databases. The DB name appears there.
# Common name pattern: BRIGHTDATA__X_TWITTER or DATAMARKET_BRIGHTDATA_TWITTER
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_TABLE=POSTS

# ---------- BrightData REST API (alternative path) ----------
# Only needed if DATA_SOURCE=brightdata. Get from BrightData → Account → API tokens.
BRIGHTDATA_API_KEY=
BRIGHTDATA_TWITTER_DATASET_ID=

# ---------- Optional: LLM reply drafting ----------
# If set, replies.py will call Claude to draft natural-language replies.
# If unset, replies fall back to template-based drafts.
ANTHROPIC_API_KEY=

# ---------- Optional: Twitter posting ----------
# Required ONLY if you want to actually send approved replies (not just queue them).
# Leaving these blank keeps the system in "draft + human-approve, no send" mode —
# the safe default.
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
